{
    "name": "midocrity",
    "private": true,
    "version": "0.4.0",
    "type": "module",
    "scripts": {
        "preinstall": "npx only-allow pnpm",
        "dev": "vite",
        "build": "VITE_GIT_VERSION=$(git describe  --tags --long) vite build",
        "preview": "vite preview",
        "lint": "biome check src && tsc --noEmit",
        "format": "biome format --write src",
        "test": "vitest --run",
        "checkall": "pnpm test && pnpm lint && pnpm build"
    },
    "devDependencies": {
        "@types/stats.js": "^0.17.4",
        "@types/three": "^0.183.1",
        "@biomejs/biome": "^2.4.6",
        "happy-dom": "^20.0.11",
        "stats.js": "^0.17.0",
        "typescript": "^5.9.3",
        "vite": "^8.0.10",
        "vitest": "^4.1.5"
    },
    "dependencies": {
        "lil-gui": "^0.21.0",
        "three": "^0.183.2"
    }
}
